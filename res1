      <h3>Input Data</h3>
      <p></p>
        <p class=error>Please correct the errors below.</p>
      <ul class="nav nav-tabs" id="myTab" roles="tablist">
        <li class="active"><a href="#basic" role="tab" data-toggle="tab">Basic</a></li>
        <li class><a href="#advanced" role="tab" data-toggle="tab">Advanced</a></li>
      </ul>
      <form role="form" action="" method="post" id="rffa_form">
        <div id="myTabContent" class="tab-content">
          <div class="tab-pane active" id="basic">
            
  <div class="form-group catchment_name-form">

    <label for="catchment_name">Catchment Name</label>

      <input class="inline form-control" id="catchment_name" name="catchment_name" type="text" value="Catchment1">

  </div>

            
  <div class="form-group lato-form">

    <label for="lato">Catchment Outlet Latitude</label>

      <input class="inline form-control" id="lato" name="lato" type="text" value="-33.8783">

      <ul class=errors>
          <li>Coordinates not within a region</li>
      </ul>
  </div>

            
  <div class="form-group lono-form">

    <label for="lono">Catchment Outlet Longitude</label>

      <input class="inline form-control" id="lono" name="lono" type="text" value="150.7683">

      <ul class=errors>
          <li>Coordinates not within a region</li>
      </ul>
  </div>

            
  <div class="form-group latc-form">

    <label for="latc">Catchment Centroid Latitude</label>

      <input class="inline form-control" id="latc" name="latc" type="text" value="-33.9607">

  </div>

            
  <div class="form-group lonc-form">

    <label for="lonc">Catchment Centroid Longitude</label>

      <input class="inline form-control" id="lonc" name="lonc" type="text" value="151.752">

  </div>

            
  <div class="form-group area-form">

    <label for="area">Catchment Area (km²)</label>

      <input class="inline form-control" id="area" name="area" type="text" value="88">

  </div>

          </div>
          <div class="tab-pane" id="advanced">
            
  <div class="form-group region-form">

    <label for="region">Region Name</label>

      <select class="inline form-control" disabled id="region" name="region"><option selected value="0">Automatic</option><option value="1">VIC + NSW + ACT + QLD</option><option value="2">Tasmania</option><option value="3">South Australia</option><option value="4">NT + Kimberley WA</option><option value="5">SW Western Australia</option><option value="6">Pilbara Arid Area</option><option value="7">All Other Arid Areas</option></select>
      <input id="region-cbox" class="cbox" type="checkbox" name="region" value=0 checked>

  </div>

            
  <div class="form-group i2_6h-form">

    <label for="i2_6h">50% AEP 6 Hour Rainfall Intensity (mm/h)<br></label>

      <input class="inline form-control" disabled id="i2_6h" name="i2_6h" type="text" value="0">
      <input id="i2_6h-cbox" class="cbox" type="checkbox" name="i2_6h" value=0 checked>

  </div>

            
  <div class="form-group i50_6h-form">

    <label for="i50_6h">2% AEP 6 Hour Rainfall Intensity (mm/h)<br></label>

      <input class="inline form-control" disabled id="i50_6h" name="i50_6h" type="text" value="0">
      <input id="i50_6h-cbox" class="cbox" type="checkbox" name="i50_6h" value=0 checked>

  </div>

          </div>
        </div>
        <button type="submit" class="btn btn-default btn-lg" value="Submit">Submit</button>
      </form>
    </div>
